# Postgres connection string.
# Local dev: docker compose up -d, then use the URL below.
# Production: Neon connection string (pooled), set in Vercel project env vars.
DATABASE_URL=postgres://streamer:streamer@localhost:5433/streamer_tools

# Auth.js. Generate with: openssl rand -base64 32
AUTH_SECRET=

# Seed credentials for the single user (used by pnpm db:seed only).
SEED_USER_EMAIL=
SEED_USER_PASSWORD=
SEED_USER_NAME=

# Email reminders (cron). All optional — without them the cron logs a stub.
# EMAIL_REMINDERS_ENABLED: set to "true" to actually send (feature flag).
# RESEND_API_KEY: Resend credential; required only when the flag is on.
# CRON_SECRET: shared secret; Vercel sends it as a Bearer token to cron routes.
EMAIL_REMINDERS_ENABLED=
RESEND_API_KEY=
CRON_SECRET=

# Public signup (feature flag). Set to "true" to expose /signup and allow the
# signup action. Keep off in production until the email domain is verified
# and EMAIL_FROM is set (BUILD_LOG NEEDS INPUT #6).
SIGNUP_ENABLED=

# Media kit generator (feature flag). Set to "true" to expose /media-kit and
# public /kit/[slug] pages.
MEDIA_KIT_ENABLED=
# YouTube Data API v3 key. Without it a deterministic stub serves plausible
# channel stats (dev/CI); real stats require the key (BUILD_LOG NEEDS INPUT #7).
YOUTUBE_API_KEY=
